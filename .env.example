MICROSOFT_TENANT_ID=your-tenant-id
# Optional. If omitted, edraft falls back to Microsoft365R's public client ID.
MICROSOFT_CLIENT_ID=
# Optional. Use "fallback" to avoid calendar consent prompts until the edraft app is approved.
EDRAFT_AUTH_MODE=auto
EDRAFT_TOKEN_CACHE_PATH=./data/msal_token_cache.bin
EDRAFT_REDIRECT_PORT=8765

OPENAI_API_KEY=your-openai-api-key
